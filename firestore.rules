rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: quizzes
    // Fields: title, description, topic, creatorId, creatorName, createdAt, questions[]
    //
    // Collection: scores
    // Fields: userId, userName, userPhoto, quizId, quizTitle, score, totalQuestions, createdAt
    //
    // Collection: users
    // Fields: uid, displayName, photoURL, totalQuizzesCreated, totalQuizzesTaken
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.creatorId;
    }

    function isValidQuiz(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.topic is string && data.topic.size() > 0 && data.topic.size() < 100 &&
             data.creatorId == request.auth.uid &&
             data.questions is list && data.questions.size() > 0 && data.questions.size() <= 20;
    }

    function isValidScore(data) {
      return data.userId == request.auth.uid &&
             data.quizId is string &&
             data.score is number && data.score >= 0 &&
             data.totalQuestions is number && data.totalQuestions > 0;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "cc9152655@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create, update: if isOwner(userId);
    }

    match /quizzes/{quizId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidQuiz(request.resource.data);
      allow update, delete: if isDocOwner() && isValidQuiz(request.resource.data);
    }

    match /scores/{scoreId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      allow update, delete: if isOwner(resource.data.userId);
    }
  }
}
